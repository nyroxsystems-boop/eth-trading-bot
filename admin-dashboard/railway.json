{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npm run build"
    },
    "deploy": {
        "startCommand": "npx serve dist -s -l $PORT",
        "region": "eu-west1",
        "numReplicas": 1,
        "sleepApplication": true
    }
}
