                                filteredPairs.map(pair => (
                                    <button
                                        key={pair.symbol}
                                        onClick={() => selectPair(pair)}
                                        disabled={loading}
                                        style={{
                                            width: '100%',
                                            padding: '12px',
                                            background: currentPair.symbol === pair.symbol
