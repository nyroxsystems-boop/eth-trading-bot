        signal = (50 - value) / 50.0  # Linear contrarian: 0→+1, 50→0, 100→-1

        result = {"value": value, "label": label, "signal": round(signal, 3), "source": "fear_greed"}
        logger.info(f"INTEL Fear&Greed: {value} ({label}) → signal={signal:.3f}")

