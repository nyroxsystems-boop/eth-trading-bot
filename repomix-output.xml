def _interval_minutes(interval_str: str) -> int:
    import re as _re
    m = _re.match(r"^(\d+)([mhd])$", interval_str.strip())
    if not m:
        return 5
    n, u = int(m.group(1)), m.group(2)
    mult = {'m': 1, 'h': 60, 'd': 1440}.get(u, 1)
    return n * mult

