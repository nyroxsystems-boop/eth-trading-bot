            <span style={{ color: (d.rsi_1m || 50) < 30 ? '#22C55E' : (d.rsi_1m || 50) > 70 ? '#F87171' : 'rgba(255,255,255,0.3)' }}>{d.rsi_1m?.toFixed(0)}</span>
            <span style={{ color: 'rgba(255,255,255,0.3)' }}>{d.bb_position?.toFixed(2)}</span>
          </div>
        ))}
