                    h1_ema20 = sum(h1_closes[-min(20, len(h1_closes)):]) / min(20, len(h1_closes))
                    h1_ema50 = sum(h1_closes[-min(len(h1_closes), 14):]) / min(len(h1_closes), 14)
                    
                    if h1_rsi < 35 and price < h1_ema20:
                        hourly_bias = "OVERSOLD_BOUNCE"
