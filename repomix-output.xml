        if age_seconds > 300:  # 5 minutes
            data["status"] = "stale"
            data["age_seconds"] = round(age_seconds)
        else:
            data["status"] = "active"
            data["age_seconds"] = round(age_seconds)
        
        return data
    except Exception as e:
        return {"status": "error", "message": str(e)}


