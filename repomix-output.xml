                                    style={{
                                        width: '100%',
                                        padding: '12px',
                                        background: 'rgba(139, 92, 246, 0.1)',
                                        border: '1px solid rgba(139, 92, 246, 0.3)',
                                        borderRadius: '8px',
                                        color: 'white'
                                    }}
                                />
                            </div>
                            <div>
                                <label style={{ fontSize: '13px', color: '#94A3B8', marginBottom: '6px', display: 'block' }}>
                                    🛑 Stop Loss (%)
                                </label>
                                <input
                                    type="number"
                                    step="0.1"
                                    value={showEditModal.stop_loss_pct}
                                    onChange={(e) => setShowEditModal(prev => prev ? { ...prev, stop_loss_pct: parseFloat(e.target.value) || 1 } : null)}
                                    style={{
                                        width: '100%',
                                        padding: '12px',
                                        background: 'rgba(139, 92, 246, 0.1)',
                                        border: '1px solid rgba(139, 92, 246, 0.3)',
                                        borderRadius: '8px',
                                        color: 'white'
                                    }}
                                />
                            </div>
                        </div>

                        <button
                            onClick={updatePair}
                            style={{
                                width: '100%',
                                padding: '14px',
                                background: 'linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%)',
                                border: 'none',
                                borderRadius: '10px',
                                color: 'white',
                                fontWeight: 600,
                                cursor: 'pointer',
                                fontSize: '16px'
                            }}
                        >
                            Save Changes
                        </button>
                    </div>
                </div>
            )}
        </div>
    )
}

