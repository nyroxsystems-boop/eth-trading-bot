                if USE_POSTGRES:
                    cursor.execute("""
                        INSERT INTO users (email, username, password_hash, role)
                        VALUES (%s, %s, %s, %s)
                        RETURNING id
                    """, (email.lower(), username, password_hash, role))
                    user_id = cursor.fetchone()[0]
                    
                    cursor.execute("""
                        INSERT INTO user_settings (user_id)
                        VALUES (%s)
                    """, (user_id,))
                else:
                    cursor.execute("""
                        INSERT INTO users (email, username, password_hash, role)
                        VALUES (?, ?, ?, ?)
                    """, (email.lower(), username, password_hash, role))
                    user_id = cursor.lastrowid
                    
