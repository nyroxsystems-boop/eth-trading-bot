                       "today_tested": 0, "this_hour_tested": 0},
            "strategies": [],
            "current_strategy": None
        }


def _pg_get_evolution(days: int) -> List[Dict]:
    """Get daily best score evolution from PostgreSQL."""
    try:
        with get_db_connection() as conn:
