          python -m py_compile risk_manager_v2.py
          echo "✅ All critical files compile clean"

  build-dashboards:
    name: Build All Dashboards
    runs-on: ubuntu-latest
    needs: test
    
    steps:
      - uses: actions/checkout@v4
      
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
      
      - name: Build User Dashboard
        working-directory: dashboard
        env:
          VITE_API_URL: ''
        run: |
          npm install
          npm run build
          test -f dist/index.html && echo "✅ User Dashboard built" || exit 1
      
      - name: Build Admin Dashboard
        working-directory: admin-dashboard
        env:
          VITE_API_URL: ''
        run: |
          npm install
          npm run build
          test -f dist/index.html && echo "✅ Admin Dashboard built" || exit 1
      
      - name: Build Strategy Monitor
        working-directory: strategy-monitor
        env:
          VITE_API_URL: ''
        run: |
          npm install
          npm run build
          test -f dist/index.html && echo "✅ Strategy Monitor built" || exit 1
</file>

