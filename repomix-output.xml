                        style={{ width: `${phase.performance_score}%` }}
                    >
                        <span>{phase.performance_score.toFixed(0)}/100</span>
                    </div>
                </div>
            </div>

            <div className="trade-stats">
                <span className="stat-item win">{phase.winning_trades} Wins</span>
