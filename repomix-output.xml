                GROUP BY DATE(created_at)
                ORDER BY day
            """ % int(days))  # Safe: days is always an int

            return [
                {"date": row[0].isoformat(), "best_score": round(row[1], 2)}
                for row in cursor.fetchall()
            ]
    except Exception as e:
        print(f"❌ PG get evolution error: {e}")
        return []


