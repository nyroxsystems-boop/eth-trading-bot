        flag_file = Path(os.getenv("LOG_DIR", "./logs")) / "EMERGENCY_STOP"
        flag_file.parent.mkdir(parents=True, exist_ok=True)
        flag_file.write_text(f"STOPPED by {current_user.get('username')} at {datetime.now().isoformat()}")
