# Binance API Credentials
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Trading Configuration
DRY_RUN=false
PAIR=ETHUSDT
BASE_ASSET=ETH
QUOTE_ASSET=USDT

# Risk Management (Optimized for 1% daily target)
MAX_TRADES_PER_DAY=15
RISK_PCT_PER_TRADE=0.006
DAILY_TARGET_PCT=0.01
MAX_DRAWDOWN_DAY=0.05

# Entry/Exit Parameters (Optimized for 1% daily)
ENTRY_SCORE_MIN=0.45
SEC_PML_MIN=0.48
TAKE_PROFIT_PCT=0.010
TP_MIN=0.010
TP_MAX=0.015
STOP_FLOOR=0.005
STOP_ATR_MULT=1.5
BREAK_EVEN_TRIGGER=0.006

# Regime Filters (Optimized for more opportunities)
ADX_MIN_TREND=15
USE_ADX_FILTER=true
RSI_MIN=40
RSI_MAX=70

# Advanced Features
FOCUS_MODE=1
TWITTER_SENTIMENT=1
OS_ENTRY_SCORE_MIN=0.28

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Capital
EQUITY_USDT=100000
PAPER_BASE_USDT=100000

# Dashboard API
DASHBOARD_PORT=8000
DASHBOARD_SECRET=change_this_secret_key_in_production
CORS_ORIGINS=*

# Data Paths (Railway will use /data volume)
LOG_DIR=/data/logs
CACHE_DIR=/data/cache
STATE_DIR=/data/state

# Security (REQUIRED in production - generate with commands shown below)
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_this_to_a_random_secret_string
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_this_to_a_fernet_key
# Set to 'production' on Railway to enforce required env vars
ENV=development

# Authentication (REQUIRED — if not set, random passwords are generated on first boot)
# python3 -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=change_this_admin_password
USER_PASSWORD=change_this_user_password

# Internal API Key (REQUIRED for bot→API sync between Worker and Web services)
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=change_this_internal_api_key
