# Environment variables for Vercel deployment
# Copy this to your Vercel project settings

# Railway API URL (replace with your actual Railway web service URL)
VITE_API_URL=https://your-railway-web-service.railway.app

# WebSocket URL (same as API URL but with ws:// or wss://)
VITE_WS_URL=wss://your-railway-web-service.railway.app
